# ──────────────────────────────────────────────────────────────────────────────
# MotionForge — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech:5432/motionforge?sslmode=require"

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional: override JWT issuer (auto-derived from publishable key if omitted)
# CLERK_JWT_ISSUER="https://your-clerk-subdomain.clerk.accounts.dev"

# ── NVIDIA Build API ───────────────────────────────────────────────────────────
# Get from: https://build.nvidia.com → API Keys
NVIDIA_API_KEY="nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_TEXT_MODEL="meta/llama-3.1-70b-instruct"
NVIDIA_VISION_MODEL="meta/llama-3.2-90b-vision-instruct"
NVIDIA_EVALUATION_MODEL="nvidia/nemotron-4-340b-instruct"

# ── UploadThing ────────────────────────────────────────────────────────────────
# Get from: https://uploadthing.com/dashboard → API Keys
UPLOADTHING_TOKEN="your_uploadthing_token"
UPLOADTHING_SECRET="your_uploadthing_secret_here"
UPLOADTHING_APP_ID="your_app_id"

# ── URLs ───────────────────────────────────────────────────────────────────────
# Frontend public URL
APP_URL="http://localhost:3000"
# Backend URL — used by Next.js server components to call FastAPI
BACKEND_URL="http://localhost:8000"
# Backend URL — used by Next.js client components (must be NEXT_PUBLIC_)
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for FastAPI
# In production: set to your Vercel URL, e.g. https://motionforge.vercel.app
BACKEND_CORS_ORIGINS="http://localhost:3000"

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="30"

# ── Render subprocess ──────────────────────────────────────────────────────────
# Override if node is at a non-standard path (e.g. /usr/local/bin/node)
# NODE_BINARY="node"

# ── Development only — NEVER set in production ─────────────────────────────────
# MOTIONFORGE_AUTH_BYPASS="false"
